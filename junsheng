    }

    .btn-outline-custom {
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    .btn-outline-custom::before {
        content: '';
        position: absolute;
        top: 0; left: -100%; width: 100%; height: 100%;
        background-color: #ff5500;
        transition: all 0.4s ease;
        z-index: -1;
    }
    .btn-outline-custom:hover::before {
